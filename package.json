{
  "name": "ds-ticket-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "register-commands": "tsx src/discord/registerCommands.ts",
    "register-commands:prod": "node dist/discord/registerCommands.js",
    "repair:descriptions": "tsx src/discord/repairTrelloDescriptions.ts",
    "repair:descriptions:prod": "node dist/discord/repairTrelloDescriptions.js",
    "backfill:tickets": "tsx src/discord/backfillTrelloTickets.ts",
    "backfill:tickets:prod": "node dist/discord/backfillTrelloTickets.js",
    "trello:webhook": "tsx src/trello/manageWebhook.ts",
    "trello:webhook:prod": "node dist/trello/manageWebhook.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
